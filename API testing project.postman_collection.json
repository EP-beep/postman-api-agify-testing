		{
			"name": "CheckIfRequiredFieldHasBeenFilled",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Response contains name\", function () {\r",
							"    let json = pm.response.json();\r",
							"    pm.expect(json).to.have.property(\"name\");\r",
							"});\r",
							"\r",
							"pm.test(\"Response is less than 200 ms\", function()\r",
							"{\r",
							"    pm.expect(pm.response.responseTime).to.be.below(200);\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://api.agify.io/?name=Elvis",
					"protocol": "https",
					"host": [
